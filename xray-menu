        "19": ("Обновить Xray", lambda: call(["xray-update", "--update"])),
        "20": ("Показать бэкапы Xray", lambda: call(["xray-update", "--backups"])),
        "21": ("Откатить Xray к предыдущей версии", rollback_xray),
    }


def menu():
    if os.geteuid() != 0:
        die("Run this script as root.")

    while True:
        print()
        print_menu_header()
        print()
        print_menu_table()
        choice = input("Выбор: ").strip()
        if not sys.stdin.isatty():
            print()

        if choice == "0":
            return
        handlers = menu_handlers()
        if choice in handlers:
            title, handler = handlers[choice]
            execute_action(title, handler)
        else:
            print("Неизвестный пункт меню.")


if __name__ == "__main__":
    menu()
