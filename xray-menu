#!/usr/bin/env python3
import json
import os
import re
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

CONFIG_PATH = Path("/usr/local/etc/xray/config.json")
SERVER_ENV_PATH = Path("/usr/local/etc/xray/server.env")
CLIENT_LINK_PATH = Path("/root/xray-reality-client.txt")
INBOUND_TAG = "vless-reality"
HOST_RE = re.compile(r"^[A-Za-z0-9.-]+$")
CLIENT_RE = re.compile(r"^[A-Za-z0-9_.@-]{1,64}$")
FINGERPRINTS = [
    "chrome",
    "firefox",
    "safari",
    "ios",
    "android",
    "edge",
    "360",
    "qq",
    "random",
    "randomized",
]


def die(message):
    print(f"ERROR: {message}", file=sys.stderr)
    sys.exit(1)


def run(command, **kwargs):
    return subprocess.run(command, check=True, **kwargs)


def validate_port(value):
    if not re.fullmatch(r"[0-9]+", value or ""):
        die("PORT must be a number from 1 to 65535.")
    port = int(value, 10)
    if port < 1 or port > 65535:
        die("PORT must be a number from 1 to 65535.")
    return port


def validate_host(value, label="SNI"):
    if not value or "/" in value or ":" in value or not HOST_RE.fullmatch(value):
        die(f"{label} must be a domain without https://, path, or port.")
    return value


def validate_fingerprint(value):
    value = (value or "").strip().lower()
    if value not in FINGERPRINTS:
        die("FINGERPRINT must be one of: " + ", ".join(FINGERPRINTS))
    return value


def validate_client_name(value):
    if not CLIENT_RE.fullmatch(value or ""):
        die("Client name must be 1-64 chars: A-Z a-z 0-9 _ . @ -")
    return value


def load_config():
    if not CONFIG_PATH.exists():
        die(f"Config not found: {CONFIG_PATH}")
    return json.loads(CONFIG_PATH.read_text())


def find_inbound(config):
    for inbound in config.get("inbounds", []):
        if inbound.get("tag") == INBOUND_TAG:
            return inbound
    for inbound in config.get("inbounds", []):
        if inbound.get("protocol") == "vless" and inbound.get("streamSettings", {}).get("security") == "reality":
            return inbound
    die("VLESS Reality inbound not found.")


def current_settings(config):
    inbound = find_inbound(config)
    reality = inbound.get("streamSettings", {}).get("realitySettings", {})
    server_names = reality.get("serverNames") or [""]
    port = int(inbound.get("port", 443))
    sni = server_names[0]
    dest = reality.get("dest", f"{sni}:{port}")
    return inbound, reality, port, sni, dest


def server_env():
    values = {}
    if SERVER_ENV_PATH.exists():
        for line in SERVER_ENV_PATH.read_text().splitlines():
            if "=" in line:
                key, value = line.split("=", 1)
                values[key] = value
    return values


def current_fingerprint():
    value = (server_env().get("FINGERPRINT") or "chrome").strip().lower()
    return value if value in FINGERPRINTS else "chrome"


def write_server_env(port, sni, dest, fingerprint=None):
    values = server_env()
    values["PORT"] = str(port)
    values["REALITY_SNI"] = sni
    values["REALITY_DEST"] = dest
    values["FINGERPRINT"] = validate_fingerprint(fingerprint) if fingerprint is not None else current_fingerprint()
    if "SERVER_ADDR" not in values:
        values["SERVER_ADDR"] = ""

    ordered = ["SERVER_ADDR", "PORT", "REALITY_SNI", "REALITY_DEST", "FINGERPRINT"]
    lines = [f"{key}={values.get(key, '')}" for key in ordered]
    for key in sorted(values):
        if key not in ordered:
            lines.append(f"{key}={values[key]}")

    tmp = SERVER_ENV_PATH.with_suffix(".env.tmp")
    tmp.write_text("\n".join(lines) + "\n")
    shutil.chown(tmp, user="root", group="xray")
    os.chmod(tmp, 0o640)
    tmp.replace(SERVER_ENV_PATH)


def write_config(config):
    timestamp = datetime.now(timezone.utc).strftime("%Y%m%d%H%M%S%f")
    backup = CONFIG_PATH.with_name(f"{CONFIG_PATH.name}.bak.{timestamp}")
    shutil.copy2(CONFIG_PATH, backup)
    tmp = CONFIG_PATH.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(config, indent=2, ensure_ascii=False) + "\n")
    shutil.chown(tmp, user="root", group="xray")
    os.chmod(tmp, 0o640)
    tmp.replace(CONFIG_PATH)
    return backup


def apply_config(config):
    backup = write_config(config)
    try:
        run(["/usr/local/bin/xray", "run", "-test", "-config", str(CONFIG_PATH)])
        run(["systemctl", "restart", "xray"])
    except subprocess.CalledProcessError:
        shutil.copy2(backup, CONFIG_PATH)
        shutil.chown(CONFIG_PATH, user="root", group="xray")
        os.chmod(CONFIG_PATH, 0o640)
        run(["systemctl", "restart", "xray"])
        die(f"New config failed. Restored backup: {backup}")
    return backup


def refresh_initial_link():
    config = load_config()
    inbound = find_inbound(config)
    clients = inbound.get("settings", {}).get("clients", [])
    if not clients:
        return
    name = clients[0].get("email", "starter").split("|created=", 1)[0]
    result = subprocess.run(
        ["xray-client", "link", name],
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    if result.returncode != 0:
        return

    _, _, port, sni, dest = current_settings(config)
    fp = current_fingerprint()
    link = result.stdout.strip()
    content = (
        f"CLIENT_URI={link}\n"
        f"PORT={port}\n"
        "PROTOCOL=VLESS\n"
        "SECURITY=REALITY\n"
        "FLOW=xtls-rprx-vision\n"
        f"SNI={sni}\n"
        f"DEST={dest}\n"
        f"FINGERPRINT={fp}\n"
    )
    CLIENT_LINK_PATH.write_text(content)
    os.chmod(CLIENT_LINK_PATH, 0o600)


def prompt(default, message):
    value = input(f"{message} [{default}]: ").strip()
    return value or str(default)


def show_settings():
    config = load_config()
    _, _, port, sni, dest = current_settings(config)
    fp = current_fingerprint()
    print()
    print("Текущие настройки:")
    print(f"  PORT={port}")
    print(f"  REALITY_SNI={sni}")
    print(f"  REALITY_DEST={dest}")
    print(f"  FINGERPRINT={fp}")
    print()


def update_port():
    config = load_config()
    inbound, reality, current_port, sni, _ = current_settings(config)
    print()
    print("Новый PORT: публичный TCP-порт для подключения клиентов.")
    print("DEST будет автоматически пересчитан как REALITY_SNI:PORT.")
    port = validate_port(prompt(current_port, "PORT"))
    dest = f"{sni}:{port}"
    inbound["port"] = port
    reality["dest"] = dest
    backup = apply_config(config)
    write_server_env(port, sni, dest)
    refresh_initial_link()
    print(f"PORT обновлён: {port}")
    print(f"REALITY_DEST обновлён: {dest}")
    print(f"Backup: {backup}")


def update_sni():
    config = load_config()
    _, reality, port, current_sni, _ = current_settings(config)
    print()
    print("Новый REALITY_SNI: реальный HTTPS-домен без https:// и без порта.")
    print("DEST будет автоматически пересчитан как REALITY_SNI:PORT.")
    sni = validate_host(prompt(current_sni, "REALITY_SNI"), "REALITY_SNI")
    dest = f"{sni}:{port}"
    reality["serverNames"] = [sni]
    reality["dest"] = dest
    backup = apply_config(config)
    write_server_env(port, sni, dest)
    refresh_initial_link()
    print(f"REALITY_SNI обновлён: {sni}")
    print(f"REALITY_DEST обновлён: {dest}")
    print(f"Backup: {backup}")


def update_port_and_sni():
    config = load_config()
    inbound, reality, current_port, current_sni, _ = current_settings(config)
    print()
    print("Обновление PORT и REALITY_SNI.")
    print("DEST будет автоматически пересчитан как REALITY_SNI:PORT.")
    port = validate_port(prompt(current_port, "PORT"))
    sni = validate_host(prompt(current_sni, "REALITY_SNI"), "REALITY_SNI")
    dest = f"{sni}:{port}"
    inbound["port"] = port
    reality["serverNames"] = [sni]
    reality["dest"] = dest
    backup = apply_config(config)
    write_server_env(port, sni, dest)
    refresh_initial_link()
    print(f"PORT обновлён: {port}")
    print(f"REALITY_SNI обновлён: {sni}")
    print(f"REALITY_DEST обновлён: {dest}")
    print(f"Backup: {backup}")


def choose_fingerprint(default):
    print()
    print("Новый FINGERPRINT: маскировка браузера/uTLS в клиентской VLESS-ссылке.")
    print("Обычно оставляют chrome. Если нужно, выбери другой профиль из списка.")
    for index, value in enumerate(FINGERPRINTS, start=1):
        print(f"  {index}) {value}")
    value = input(f"FINGERPRINT [{default}] (номер или значение): ").strip().lower()
    value = value or default
    if value.isdigit():
        index = int(value, 10)
        if 1 <= index <= len(FINGERPRINTS):
            return FINGERPRINTS[index - 1]
    return validate_fingerprint(value)


def update_fingerprint():
    config = load_config()
    _, _, port, sni, dest = current_settings(config)
    fp = choose_fingerprint(current_fingerprint())
    write_server_env(port, sni, dest, fp)
    refresh_initial_link()
    print(f"FINGERPRINT обновлён: {fp}")
    print("Xray перезапускать не нужно. Выведи клиенту новую ссылку через xray-client link ИМЯ.")


def call(command):
    subprocess.run(command, check=False)


def ask_name(action):
    name = input(f"Имя клиента для {action}: ").strip()
    return validate_client_name(name)


def print_initial_link():
    if CLIENT_LINK_PATH.exists():
        print(CLIENT_LINK_PATH.read_text())
    else:
        print("Файл /root/xray-reality-client.txt не найден. Можно вывести ссылку через xray-client link NAME.")


def confirm(message):
    answer = input(f"{message} [y/N]: ").strip().lower()
    return answer in ("y", "yes")


def rollback_xray():
    if confirm("Откатить Xray к последней сохранённой предыдущей версии?"):
        call(["xray-update", "--rollback"])
    else:
        print("Откат отменён.")


def menu():
    if os.geteuid() != 0:
        die("Run this script as root.")

    while True:
        print()
        print("Xray menu")
        print("1) Показать текущие настройки")
        print("2) Обновить PORT")
        print("3) Обновить REALITY_SNI и REALITY_DEST")
        print("4) Обновить PORT, REALITY_SNI и REALITY_DEST")
        print("5) Обновить FINGERPRINT")
        print("6) Показать клиентов")
        print("7) Добавить клиента")
        print("8) Отключить клиента")
        print("9) Включить клиента")
        print("10) Удалить клиента")
        print("11) Вывести ссылку клиента")
        print("12) Добавить/заменить каскад")
        print("13) Проверить каскад")
        print("14) Отключить каскад")
        print("15) Статус Xray")
        print("16) Перезапустить Xray")
        print("17) Вывести стартовую ссылку")
        print("18) Проверить Xray и доступность обновления")
        print("19) Обновить Xray")
        print("20) Показать бэкапы Xray")
        print("21) Откатить Xray к предыдущей версии")
        print("0) Выход")
        choice = input("Выбор: ").strip()

        if choice == "1":
            show_settings()
        elif choice == "2":
            update_port()
        elif choice == "3":
            update_sni()
        elif choice == "4":
            update_port_and_sni()
        elif choice == "5":
            update_fingerprint()
        elif choice == "6":
            call(["xray-client", "list"])
        elif choice == "7":
            call(["xray-client", "add", ask_name("добавления")])
        elif choice == "8":
            call(["xray-client", "disable", ask_name("отключения")])
        elif choice == "9":
            call(["xray-client", "enable", ask_name("включения")])
        elif choice == "10":
            call(["xray-client", "remove", ask_name("удаления")])
        elif choice == "11":
            call(["xray-client", "link", ask_name("вывода ссылки")])
        elif choice == "12":
            call(["xray-set-cascade"])
        elif choice == "13":
            call(["xray-set-cascade", "--test"])
        elif choice == "14":
            call(["xray-set-cascade", "--disable"])
        elif choice == "15":
            call(["systemctl", "status", "xray", "--no-pager"])
        elif choice == "16":
            call(["systemctl", "restart", "xray"])
            call(["systemctl", "is-active", "xray"])
        elif choice == "17":
            print_initial_link()
        elif choice == "18":
            call(["xray-update", "--check"])
        elif choice == "19":
            call(["xray-update", "--update"])
        elif choice == "20":
            call(["xray-update", "--backups"])
        elif choice == "21":
            rollback_xray()
        elif choice == "0":
            return
        else:
            print("Неизвестный пункт меню.")


if __name__ == "__main__":
    menu()
